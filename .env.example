# Copy to .env and edit before production deploy
STOCKLY_ENV=production
STOCKLY_HOST=0.0.0.0
STOCKLY_PORT=5001
STOCKLY_WORKERS=2
STOCKLY_THREADS=4
STOCKLY_TIMEOUT=300

# REQUIRED in production — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
STOCKLY_SECRET_KEY=change-me-to-a-long-random-hex

# Behind HTTPS reverse proxy (nginx/caddy). Set 0 only for plain-HTTP LAN testing.
STOCKLY_COOKIE_SECURE=1
STOCKLY_COOKIE_SAMESITE=Lax
STOCKLY_TRUST_PROXY=1

STOCKLY_SESSION_DAYS=14
STOCKLY_DATA_DIR=/app/data

# First-boot admin (only used if DB is empty). Force-changed on first login.
STOCKLY_ADMIN_USER=admin
STOCKLY_ADMIN_PASS=admin123

# Residential/mobile proxy for scrapers. Grocery apps (Instamart, Zepto) block
# datacenter IPs, so on a cloud host their search returns 403 / login walls.
# Route scraper traffic through a residential proxy to look like a real user.
# Leave blank to connect directly (fine for local dev on a home connection).
STOCKLY_PROXY_SERVER=
STOCKLY_PROXY_USERNAME=
STOCKLY_PROXY_PASSWORD=
